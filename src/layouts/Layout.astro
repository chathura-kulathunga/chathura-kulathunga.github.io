---
import '../styles/global.css'; 
import { ClientRouter } from 'astro:transitions'; 

const { title = "CK // Vault" } = Astro.props;

// Bulletproof check: Are we on the homepage?
const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '/index.html' || pathname === '';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <ClientRouter />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;900&display=swap" rel="stylesheet">
    
    <script is:inline>
      const applyTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme') === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }
      };
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>

    <style is:global>
      body { font-family: 'Inter', sans-serif; }
    </style>
  </head>
  
  <body class="bg-[#F8F9FA] text-zinc-900 dark:bg-[#121212] dark:text-zinc-200 antialiased min-h-screen flex flex-col transition-colors duration-500 overflow-x-hidden">
    
    {/* ========================================= */}
    {/* FIGMA-GRADE MASTER HEADER                 */}
    {/* ========================================= */}
    <nav class="w-full fixed top-0 z-40 bg-[#F8F9FA]/90 dark:bg-[#121212]/90 backdrop-blur-md border-b border-zinc-200/50 dark:border-zinc-800/50 transition-colors duration-500">
      <div class="max-w-7xl mx-auto px-6 md:px-12 py-5 flex items-center justify-between">
        
        {/* Left Side: MOBILE Hamburger Button (Only shown on homepage!) */}
        {isHome && (
          <button id="mobile-menu-open" class="md:hidden p-2 -ml-2 text-zinc-900 dark:text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
          </button>
        )}

        {/* Center/Left: Logo / Home Button */}
        <a href="/" id="desktop-home-link" class="text-zinc-900 dark:text-white font-black tracking-[0.2em] uppercase text-sm hover:opacity-70 transition-opacity shrink-0">
          CK // Vault
        </a>
        
        {/* Right Side: DESKTOP Links */}
        <div class="hidden md:flex items-center gap-6 text-xs font-bold uppercase tracking-widest text-zinc-500 dark:text-zinc-400">
          
          {/* THESE ARE NOW BUTTONS: Zero URL Pollution! */}
          {isHome && (
            <>
              <button class="filter-nav-link hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="software">Software</button>
              <button class="filter-nav-link hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="robotics">Robotics</button>
              <button class="filter-nav-link hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="cybersecurity">Cybersec</button>
              <button class="filter-nav-link hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="sports">Sports</button>
              <button class="filter-nav-link hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="music">Music</button>
              <button class="filter-nav-link hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="psychology">Psychology</button>
            </>
          )}

          {/* Theme Toggle */}
          <button class="theme-toggle-btn ml-4 p-2 text-zinc-900 dark:text-white hover:opacity-70 transition-opacity">
            <svg class="w-4 h-4 theme-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"></svg>
          </button>
        </div>

      </div>
    </nav>

    {/* ========================================= */}
    {/* MOBILE SLIDING DRAWER (LEFT SIDE)         */}
    {/* ========================================= */}
    {isHome && (
      <>
        <div id="mobile-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 opacity-0 pointer-events-none transition-opacity duration-300"></div>
        
        <div id="mobile-drawer" class="fixed top-0 left-0 w-64 h-full bg-[#F8F9FA] dark:bg-[#121212] z-50 transform -translate-x-full transition-transform duration-300 shadow-2xl flex flex-col border-r border-zinc-200/50 dark:border-zinc-800/50">
          
          <div class="flex items-center justify-between p-6 border-b border-zinc-200/50 dark:border-zinc-800/50 shrink-0">
            <button id="mobile-menu-close" class="p-2 -ml-2 text-zinc-900 dark:text-white hover:opacity-70 transition-opacity">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
            <button class="theme-toggle-btn p-2 -mr-2 text-zinc-900 dark:text-white hover:opacity-70 transition-opacity">
              <svg class="w-5 h-5 theme-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"></svg>
            </button>
          </div>

          <div class="flex flex-col gap-6 p-8 text-sm font-bold uppercase tracking-widest text-zinc-500 dark:text-zinc-400 overflow-y-auto hide-scrollbar grow">
            <a href="/" id="mobile-home-btn" class="text-zinc-900 dark:text-white border-b border-zinc-200/50 dark:border-zinc-800/50 pb-4 mb-2 block">Home</a>
            
            <button class="filter-nav-link text-left w-full hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="software">Software</button>
            <button class="filter-nav-link text-left w-full hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="robotics">Robotics</button>
            <button class="filter-nav-link text-left w-full hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="cybersecurity">Cybersec</button>
            <button class="filter-nav-link text-left w-full hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="sports">Sports</button>
            <button class="filter-nav-link text-left w-full hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="music">Music</button>
            <button class="filter-nav-link text-left w-full hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="psychology">Psychology</button>
          </div>
          
        </div>
      </>
    )}

    {/* Main Content Area */}
    <main class="grow w-full pt-28 z-0 relative">
      <slot />
    </main>

    {/* ========================================= */}
    {/* UNIFIED JAVASCRIPT ENGINE                 */}
    {/* ========================================= */}
    <script>
      const setupLayoutScripts = () => {
        // --- 1. MOBILE MENU LOGIC ---
        const openBtn = document.getElementById('mobile-menu-open');
        const closeBtn = document.getElementById('mobile-menu-close');
        const drawer = document.getElementById('mobile-drawer');
        const overlay = document.getElementById('mobile-overlay');
        const navLinks = document.querySelectorAll('.filter-nav-link'); 
        const homeBtn = document.getElementById('mobile-home-btn');
        const desktopHome = document.getElementById('desktop-home-link');

        const openMenu = () => {
          drawer?.classList.remove('-translate-x-full');
          overlay?.classList.remove('opacity-0', 'pointer-events-none');
          document.body.style.overflow = 'hidden'; 
        };

        const closeMenu = () => {
          drawer?.classList.add('-translate-x-full');
          overlay?.classList.add('opacity-0', 'pointer-events-none');
          document.body.style.overflow = ''; 
        };

        openBtn?.addEventListener('click', openMenu);
        closeBtn?.addEventListener('click', closeMenu);
        overlay?.addEventListener('click', closeMenu);

        // ALWAYS clear memory when they click Home!
        const triggerHomeReset = (e: Event) => {
          sessionStorage.setItem('vaultActiveTab', 'default');
          
          if (window.location.pathname === '/' || window.location.pathname === '/index.html') {
             e.preventDefault();
             window.scrollTo({ top: 0, behavior: 'smooth' });
             closeMenu();
             window.dispatchEvent(new Event('vaultHomeReset')); 
          }
          // If they are on an article, the <a> tag naturally navigates them to '/' with a cleared memory!
        };

        homeBtn?.addEventListener('click', triggerHomeReset);
        desktopHome?.addEventListener('click', triggerHomeReset);

        navLinks.forEach(link => {
          link.addEventListener('click', () => {
             if (window.innerWidth < 768) closeMenu();
          });
        });

        window.addEventListener('resize', () => {
            if (window.innerWidth >= 768) closeMenu();
        });

        // --- 2. MULTI-BUTTON THEME LOGIC ---
        const themeButtons = document.querySelectorAll('.theme-toggle-btn');
        const updateIcons = () => {
          const isDark = document.documentElement.classList.contains("dark");
          themeButtons.forEach(btn => {
            const icon = btn.querySelector('.theme-icon');
            if(icon) {
              if (isDark) {
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>';
              } else {
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>';
              }
            }
          });
        };

        themeButtons.forEach(btn => {
          btn.addEventListener('click', () => {
            document.documentElement.classList.toggle("dark");
            const isDark = document.documentElement.classList.contains("dark");
            localStorage.setItem("theme", isDark ? "dark" : "light");
            updateIcons();
          });
        });

        updateIcons();
      };

      document.addEventListener('astro:page-load', setupLayoutScripts);
    </script>
  </body>
</html>