---
import '../styles/global.css'; 
import { ClientRouter } from 'astro:transitions'; 

const { title = "CK // Vault" } = Astro.props;

const pathname = Astro.url.pathname;
// Show filters on Home AND the new Vault page
const showFilters = pathname === '/' || pathname === '/index.html' || pathname === '' || pathname.startsWith('/vault');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{title}</title>
    <ClientRouter />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;900&display=swap" rel="stylesheet">
    
    <script is:inline>
      const applyTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme') === 'light') {
          document.documentElement.classList.remove('dark');
          document.documentElement.style.colorScheme = 'light';
        } else {
          document.documentElement.classList.add('dark');
          document.documentElement.style.colorScheme = 'dark';
        }
      };
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>

    <style is:global>
      body { font-family: 'Inter', sans-serif; }
    </style>
  </head>
  
  <body class="bg-[#F8F9FA] text-zinc-900 dark:bg-[#121212] dark:text-zinc-200 antialiased min-h-screen flex flex-col transition-colors duration-500 overflow-x-hidden">
    
    <nav class="w-full fixed top-0 z-40 bg-[#F8F9FA]/90 dark:bg-[#121212]/90 backdrop-blur-md border-b border-zinc-200/50 dark:border-zinc-800/50 transition-colors duration-500">
      <div class="max-w-7xl mx-auto px-6 md:px-12 py-5 flex items-center justify-between">
        
        <button id="mobile-menu-open" class="md:hidden p-2 -ml-2 text-zinc-900 dark:text-white">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>

        <a href="/" id="desktop-home-link" class="text-zinc-900 dark:text-white font-black tracking-[0.2em] uppercase text-sm hover:opacity-70 transition-opacity shrink-0">
          CK // Vault
        </a>
        
        <div class="hidden md:flex items-center gap-6 text-xs font-bold uppercase tracking-widest text-zinc-500 dark:text-zinc-400">
          
          {/* THESE ARE NOW LINKS TO THE VAULT */}
          {showFilters && (
            <>
              <a href="/vault" class="filter-nav-link hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="software">Software</a>
              <a href="/vault" class="filter-nav-link hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="robotics">Robotics</a>
              <a href="/vault" class="filter-nav-link hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="cybersecurity">Cybersec</a>
              <a href="/vault" class="filter-nav-link hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="sports">Sports</a>
              <a href="/vault" class="filter-nav-link hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="music">Music</a>
              <a href="/vault" class="filter-nav-link hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="psychology">Psychology</a>
            </>
          )}

          {showFilters && <div class="w-px h-4 bg-zinc-300 dark:bg-zinc-700 mx-2"></div>}
          
          <a href="/about" class={`global-nav-link hover:text-zinc-900 dark:hover:text-white transition-colors ${pathname.includes('/about') ? 'text-zinc-900 dark:text-white' : ''}`}>About</a>
          <a href="/contact" class={`global-nav-link hover:text-zinc-900 dark:hover:text-white transition-colors ${pathname.includes('/contact') ? 'text-zinc-900 dark:text-white' : ''}`}>Contact</a>

          <button class="theme-toggle-btn ml-4 p-2 text-zinc-900 dark:text-white hover:opacity-70 transition-opacity">
            <svg class="w-4 h-4 theme-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"></svg>
          </button>
        </div>

      </div>
    </nav>

    <div id="mobile-overlay" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 opacity-0 pointer-events-none transition-opacity duration-300"></div>
    
    <div id="mobile-drawer" class="fixed top-0 left-0 w-64 h-full bg-[#F8F9FA] dark:bg-[#121212] z-50 transform -translate-x-full transition-transform duration-300 shadow-2xl flex flex-col border-r border-zinc-200/50 dark:border-zinc-800/50">
      
      <div class="flex items-center justify-between p-6 border-b border-zinc-200/50 dark:border-zinc-800/50 shrink-0">
        <button id="mobile-menu-close" class="p-2 -ml-2 text-zinc-900 dark:text-white hover:opacity-70 transition-opacity">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
        <button class="theme-toggle-btn p-2 -mr-2 text-zinc-900 dark:text-white hover:opacity-70 transition-opacity">
          <svg class="w-5 h-5 theme-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"></svg>
        </button>
      </div>

      <div class="flex flex-col gap-6 p-8 text-sm font-bold uppercase tracking-widest text-zinc-500 dark:text-zinc-400 overflow-y-auto hide-scrollbar grow">
        
        <a href="/" id="mobile-home-btn" class="global-nav-link hover:text-zinc-900 dark:hover:text-white transition-colors">Home</a>
        <a href="/about" class={`global-nav-link hover:text-zinc-900 dark:hover:text-white transition-colors ${pathname.includes('/about') ? 'text-zinc-900 dark:text-white' : ''}`}>About</a>
        <a href="/contact" class={`global-nav-link border-b border-zinc-200/50 dark:border-zinc-800/50 pb-6 mb-2 hover:text-zinc-900 dark:hover:text-white transition-colors ${pathname.includes('/contact') ? 'text-zinc-900 dark:text-white' : ''}`}>Contact</a>
        
        {showFilters && (
          <>
            <a href="/vault" class="filter-nav-link text-left w-full hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="software">Software</a>
            <a href="/vault" class="filter-nav-link text-left w-full hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="robotics">Robotics</a>
            <a href="/vault" class="filter-nav-link text-left w-full hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="cybersecurity">Cybersec</a>
            <a href="/vault" class="filter-nav-link text-left w-full hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="sports">Sports</a>
            <a href="/vault" class="filter-nav-link text-left w-full hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="music">Music</a>
            <a href="/vault" class="filter-nav-link text-left w-full hover:text-zinc-900 dark:hover:text-white transition-colors" data-target="psychology">Psychology</a>
          </>
        )}
      </div>
      
    </div>

    <main class="grow w-full pt-28 z-0 relative">
      <slot />
    </main>

    <footer class="w-full relative overflow-hidden bg-white dark:bg-[#0A0A0A] border-t border-zinc-200/50 dark:border-zinc-800/50 pt-15 pb-10 transition-colors duration-500 mt-auto z-10">
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full overflow-hidden pointer-events-none select-none opacity-[0.03] dark:opacity-[0.02] flex justify-center z-0">
        <span class="text-[18vw] font-black tracking-tighter leading-none whitespace-nowrap text-zinc-900 dark:text-white">
          CHATHURA
        </span>
      </div>
      <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10 flex flex-col md:flex-row justify-between gap-16 md:gap-8">
        <div class="flex flex-col items-start max-w-sm">
          <a href="/" class="text-zinc-900 dark:text-white font-black tracking-[0.3em] uppercase text-xl mb-6 hover:opacity-70 transition-opacity">CK // Vault</a>
          <p class="text-zinc-500 dark:text-zinc-400 text-sm font-medium leading-relaxed mb-8">Engineered logic. Behavioral design. Shotokan discipline. Built from the ground up for absolute precision.</p>
          <div class="flex items-center gap-3 text-[10px] font-bold tracking-[0.2em] uppercase text-zinc-900 dark:text-zinc-500">
            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse shadow-[0_0_8px_rgba(34,197,94,0.6)]"></span>
            All Systems Operational
          </div>
        </div>
        <div class="flex gap-16 md:gap-24">
          <div class="flex flex-col gap-5 text-xs font-bold tracking-[0.2em] uppercase">
            <h4 class="text-zinc-900 dark:text-white mb-2 border-b border-zinc-200 dark:border-zinc-800 pb-4">Sitemap</h4>
            <a href="/" class="text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors">Home</a>
            <a href="/about" class="text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors">The Architect</a>
            <a href="/contact" class="text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors">Contact</a>
          </div>
          <div class="flex flex-col gap-5 text-xs font-bold tracking-[0.2em] uppercase">
            <h4 class="text-zinc-900 dark:text-white mb-2 border-b border-zinc-200 dark:border-zinc-800 pb-4">Network</h4>
            <a href="https://github.com/chathura-kulathunga" target="_blank" class="text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors">GitHub</a>
            <a href="https://linkedin.com/" target="_blank" class="text-zinc-500 hover:text-[#0A66C2] transition-colors">LinkedIn</a>
            <a href="https://instagram.com/" target="_blank" class="text-zinc-500 hover:text-[#E1306C] transition-colors">Instagram</a>
          </div>
        </div>
      </div>
      <div class="max-w-7xl mx-auto px-6 md:px-12 mt-20 flex flex-col md:flex-row items-center justify-between gap-6 text-[10px] font-bold tracking-[0.2em] uppercase text-zinc-500 relative z-10 border-t border-zinc-200/50 dark:border-zinc-800/50 pt-8">
        <p>© {new Date().getFullYear()} Chathura Kulathunga. All Rights Reserved.</p>
        <button id="back-to-top" class="hover:text-zinc-900 dark:hover:text-white transition-colors flex items-center gap-3 group cursor-pointer">
          <span class="w-8 h-px bg-zinc-400 group-hover:bg-zinc-900 dark:group-hover:bg-white transition-colors"></span>
          Back To Top
          <svg class="w-4 h-4 group-hover:-translate-y-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path></svg>
        </button>
      </div>
    </footer>

    <script>
      const setupLayoutScripts = () => {
        const openBtn = document.getElementById('mobile-menu-open');
        const closeBtn = document.getElementById('mobile-menu-close');
        const drawer = document.getElementById('mobile-drawer');
        const overlay = document.getElementById('mobile-overlay');
        const navLinks = document.querySelectorAll('.filter-nav-link'); 
        const globalLinks = document.querySelectorAll('.global-nav-link'); 
        const homeBtn = document.getElementById('mobile-home-btn');
        const desktopHome = document.getElementById('desktop-home-link');

        const openMenu = () => {
          drawer?.classList.remove('-translate-x-full');
          overlay?.classList.remove('opacity-0', 'pointer-events-none');
          document.body.style.overflow = 'hidden'; 
        };

        const closeMenu = () => {
          drawer?.classList.add('-translate-x-full');
          overlay?.classList.add('opacity-0', 'pointer-events-none');
          document.body.style.overflow = ''; 
        };

        openBtn?.addEventListener('click', openMenu);
        closeBtn?.addEventListener('click', closeMenu);
        overlay?.addEventListener('click', closeMenu);

        const triggerHomeReset = (e: Event) => {
          sessionStorage.setItem('vaultActiveTab', 'default');
          if (window.location.pathname === '/' || window.location.pathname === '/index.html') {
             e.preventDefault();
             window.scrollTo({ top: 0, behavior: 'smooth' });
             closeMenu();
             window.dispatchEvent(new Event('vaultHomeReset')); 
          }
        };

        homeBtn?.addEventListener('click', triggerHomeReset);
        desktopHome?.addEventListener('click', triggerHomeReset);

        // UPGRADED NAV LOGIC: Handles cross-page memory swapping!
        navLinks.forEach(link => {
          link.addEventListener('click', (e) => {
            // FIX: Added `|| 'default'` to guarantee a string for TypeScript!
            const targetCategory = link.getAttribute('data-target') || 'default';
            sessionStorage.setItem('vaultActiveTab', targetCategory);
     
            // If we are ALREADY on the vault page, don't reload. Just swap views!
            if (window.location.pathname === '/vault' || window.location.pathname === '/vault/') {
              e.preventDefault();
              window.dispatchEvent(new CustomEvent('vaultTabChange', { detail: targetCategory }));
            }  
            if (window.innerWidth < 768) closeMenu();
          });
        });

        globalLinks.forEach(link => {
          link.addEventListener('click', () => {
             if (window.innerWidth < 768) closeMenu();
          });
        });

        window.addEventListener('resize', () => {
            if (window.innerWidth >= 768) closeMenu();
        });

        const backToTopBtn = document.getElementById('back-to-top');
        backToTopBtn?.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        const themeButtons = document.querySelectorAll('.theme-toggle-btn');
        const updateIcons = () => {
          const isDark = document.documentElement.classList.contains("dark");
          themeButtons.forEach(btn => {
            const icon = btn.querySelector('.theme-icon');
            if(icon) {
              if (isDark) {
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>';
              } else {
                icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>';
              }
            }
          });
        };

        themeButtons.forEach(btn => {
          btn.addEventListener('click', () => {
            document.documentElement.classList.toggle("dark");
            const isDark = document.documentElement.classList.contains("dark");
            localStorage.setItem("theme", isDark ? "dark" : "light");
            document.documentElement.style.colorScheme = isDark ? "dark" : "light";
            updateIcons();
          });
        });

        updateIcons();
      };

      document.addEventListener('astro:page-load', setupLayoutScripts);
    </script>
  </body>
</html>