---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions'; 

const { title = "The Vault | Chathura Kulathunga" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <ClientRouter />
    
    {/* This script runs instantly to stop the screen from flashing white on load */}
    <script is:inline>
      const applyTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme') === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          document.documentElement.classList.add('dark');
        }
      };
      
      // Run immediately on first load
      applyTheme();
      
      // Run IMMEDIATELY after Astro swaps the page, before it paints to the screen!
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
  </head>
  
  {/* Notice the dark: classes! This makes the background switch colors smoothly. */}
  <body class="bg-zinc-50 text-zinc-900 dark:bg-zinc-950 dark:text-zinc-300 font-sans antialiased min-h-screen flex flex-col transition-colors duration-500">
    
    <nav class="border-b border-zinc-200 dark:border-zinc-900 bg-white/80 dark:bg-zinc-950/80 backdrop-blur-md sticky top-0 z-50 transition-colors duration-500">
      <div class="max-w-7xl mx-auto px-8 md:px-16 py-5 flex justify-between items-center">
        <a href="/" class="text-zinc-900 dark:text-white font-bold tracking-widest uppercase text-sm hover:text-zinc-500 transition-colors">
          CK // Vault
        </a>
        
        <div class="flex items-center gap-8 text-sm font-bold text-zinc-500 uppercase tracking-wider">
          <a href="/" class="hover:text-zinc-900 dark:hover:text-white transition-colors">Vault</a>
          <a href="/about" class="hover:text-zinc-900 dark:hover:text-white transition-colors">The Architect</a>
          <a href="https://github.com/chathura-kulathunga" target="_blank" class="hover:text-zinc-900 dark:hover:text-white transition-colors">GitHub ↗</a>
          
          {/* THE NEW TOGGLE BUTTON! */}
          <button id="theme-toggle" class="p-2 rounded-full bg-zinc-200 dark:bg-zinc-800 text-zinc-900 dark:text-yellow-400 hover:bg-zinc-300 dark:hover:bg-zinc-700 transition-all">
            <svg id="theme-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              </svg>
          </button>

        </div>
      </div>
    </nav>

    <main class="grow w-full">
      <slot />
    </main>

    <footer class="border-t border-zinc-200 dark:border-zinc-900 py-8 mt-auto transition-colors duration-500">
      <div class="max-w-7xl mx-auto px-8 md:px-16 text-center text-xs text-zinc-500 font-bold tracking-widest uppercase">
        © {new Date().getFullYear()} Chathura Kulathunga // All Systems Operational.
      </div>
    </footer>

    {/* The JavaScript Engine for the Button */}
    <script>
      const setupTheme = () => {
        const button = document.getElementById("theme-toggle");
        const icon = document.getElementById("theme-icon");
        
        if (!button || !icon) return;

        const updateIcon = () => {
          const isDark = document.documentElement.classList.contains("dark");
          if (isDark) {
            // Draw a Moon
            icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>';
          } else {
            // Draw a Sun
            icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>';
          }
        };

        // Use onclick so Astro doesn't duplicate listeners when caching pages!
        button.onclick = () => {
          document.documentElement.classList.toggle("dark");
          const isDark = document.documentElement.classList.contains("dark");
          localStorage.setItem("theme", isDark ? "dark" : "light");
          updateIcon();
        };

        updateIcon();
      };

      // This makes sure the button keeps working even after Astro page transitions!
      document.addEventListener('astro:page-load', setupTheme);
    </script>

  </body>
</html>