---
import Layout from '../layouts/Layout.astro';
---

<Layout title="The Architect | CK Vault">
  
  <div class="max-w-4xl mx-auto px-6 md:px-12 py-16 md:py-24">
    
    {/* ========================================= */}
    {/* ABOUT ME SECTION                          */}
    {/* ========================================= */}
    <div class="flex flex-col items-center text-center animate-fade-in">
      
      {/* Boxed Header */}
      <div class="border-4 border-zinc-900 dark:border-white px-8 py-4 mb-12 inline-block">
        <h1 class="text-2xl md:text-3xl font-black text-zinc-900 dark:text-white tracking-[0.3em] uppercase">
          The Architect
        </h1>
      </div>

      {/* Bio Text */}
      <div class="text-zinc-600 dark:text-zinc-400 font-medium leading-loose md:text-lg max-w-3xl space-y-6 text-justify md:text-center">
        <p>
          My name is <span class="text-zinc-900 dark:text-white font-bold">Chathura Kulathunga</span>. I am a 22-year-old Software Engineering undergraduate based in Sri Lanka, driven by a deep fascination with how complex systems operate—both in silicon and in the human mind.
        </p>
        <p>
          Beyond writing code, I am a <span class="text-zinc-900 dark:text-white font-bold">1st Dan Black Belt and Shotokan Karate Sensei</span>. The discipline required in the dojo directly translates to my architecture: precise, deliberate, and engineered for impact. Whether I am building enterprise-grade applications, exploring offensive cybersecurity vectors, or analyzing behavioral psychology, my approach remains the same.
        </p>
        <p class="italic text-sm">
          "Clean, classy, and relentlessly efficient."
        </p>
      </div>

      {/* Button */}
      <div class="mt-16 flex items-center justify-center gap-6 group cursor-pointer">
        <div class="h-8 w-0.5 bg-zinc-900 dark:bg-white group-hover:scale-y-150 transition-transform duration-300"></div>
        <a href="/" class="text-sm font-black text-zinc-900 dark:text-white tracking-[0.2em] uppercase group-hover:opacity-70 transition-opacity">
          Explore The Vault
        </a>
        <div class="h-8 w-0.5 bg-zinc-900 dark:bg-white group-hover:scale-y-150 transition-transform duration-300"></div>
      </div>

    </div>

    {/* ========================================= */}
    {/* FIGMA DIVIDER - h-[2px] swapped for h-0.5 */}
    {/* ========================================= */}
    <div class="flex items-center justify-center gap-4 my-24 opacity-60">
      <div class="h-0.5 w-16 bg-zinc-900 dark:bg-white"></div>
      <div class="flex gap-1 text-zinc-900 dark:text-white font-black tracking-tighter transform -skew-x-12 text-xl">\\\\//</div>
      <div class="h-0.5 w-16 bg-zinc-900 dark:bg-white"></div>
    </div>

    {/* ========================================= */}
    {/* SKILLS SECTION                            */}
    {/* ========================================= */}
    <div class="flex flex-col items-center animate-fade-in pb-12">
      
      {/* Boxed Header */}
      <div class="border-4 border-zinc-900 dark:border-white px-8 py-4 mb-16 inline-block">
        <h2 class="text-xl md:text-2xl font-black text-zinc-900 dark:text-white tracking-[0.3em] uppercase">
          Arsenal
        </h2>
      </div>

      <div class="w-full grid grid-cols-1 md:grid-cols-3 gap-16 text-center">
        
        {/* Core Stack */}
        <div>
          <h3 class="text-sm font-black text-zinc-900 dark:text-white tracking-[0.2em] uppercase mb-8">Active Stack</h3>
          <ul class="space-y-4 text-zinc-500 dark:text-zinc-400 font-bold text-sm tracking-widest uppercase">
            <li>Java</li>
            <li>PHP</li>
            <li>JavaScript</li>
            <li>MySQL</li>
            <li>Tailwind CSS</li>
          </ul>
        </div>

        {/* Learning */}
        <div>
          <h3 class="text-sm font-black text-zinc-900 dark:text-white tracking-[0.2em] uppercase mb-8">Exploring</h3>
          <ul class="space-y-4 text-zinc-500 dark:text-zinc-400 font-bold text-sm tracking-widest uppercase">
            <li>MERN Stack</li>
            <li>React Native</li>
            <li>Flutter</li>
            <li>Kali Linux</li>
            <li>Burp Suite</li>
          </ul>
        </div>

        {/* Disciplines */}
        <div>
          <h3 class="text-sm font-black text-zinc-900 dark:text-white tracking-[0.2em] uppercase mb-8">Disciplines</h3>
          <ul class="space-y-4 text-zinc-500 dark:text-zinc-400 font-bold text-sm tracking-widest uppercase">
            <li>Software Arch.</li>
            <li>Offensive Security</li>
            <li>Shotokan Do</li>
            <li>Psychology</li>
            <li>Robotics (VELOX)</li>
          </ul>
        </div>

      </div>

    </div>

  </div>

</Layout>

<style>
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>