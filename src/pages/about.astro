---
import Layout from '../layouts/Layout.astro';
---

<Layout title="The Architect | Chathura Kulathunga">
  
  <div class="max-w-4xl mx-auto px-8 md:px-16 py-16">
    
    {/* Hero Section */}
    <header class="mb-16 border-b border-zinc-200 dark:border-zinc-800 pb-12 transition-colors duration-500">
      <h1 class="text-5xl md:text-7xl font-bold text-zinc-900 dark:text-white tracking-tight mb-4 transition-colors duration-500">
        Chathura Kulathunga.
      </h1>
      <p class="text-xl text-zinc-600 dark:text-zinc-400 font-medium tracking-wide transition-colors duration-500">
        Software Engineer // 1st Dan Shotokan Sensei // Hardware Architect
      </p>
    </header>

    {/* The Mindset */}
    <section class="mb-16">
      <h2 class="text-2xl font-bold text-zinc-900 dark:text-white mb-6 uppercase tracking-widest transition-colors duration-500">I. The Mindset</h2>
      <div class="prose max-w-none text-zinc-700 dark:text-zinc-300 leading-relaxed transition-colors duration-500 text-lg">
        <p class="mb-6">
          Engineering is not just about writing syntax; it is about understanding the human element behind the screen. My approach to architecture bridges the gap between deep technical software engineering and behavioral psychology. Whether I am analyzing network vulnerabilities or designing user interfaces, the goal is always to build systems that feel instinctively powerful.
        </p>
        <p>
          I operate on a philosophy of clean aesthetics, calculated precision, and absolute discipline. 
        </p>
      </div>
    </section>

    {/* The Disciplines Grid */}
    <section class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
      
      {/* Software & Cyber */}
      <div class="p-8 bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl transition-colors duration-500">
        <h3 class="text-xl font-bold text-zinc-900 dark:text-white mb-4 transition-colors duration-500">Digital Architecture</h3>
        <ul class="space-y-3 text-zinc-600 dark:text-zinc-400 transition-colors duration-500">
          <li class="flex items-center gap-2"><span class="text-yellow-500">✦</span> Full-Stack Development (Java, PHP, MERN)</li>
          <li class="flex items-center gap-2"><span class="text-yellow-500">✦</span> Mobile Engineering (React Native, Flutter)</li>
          <li class="flex items-center gap-2"><span class="text-yellow-500">✦</span> Offensive Security & Ethical Hacking</li>
          <li class="flex items-center gap-2"><span class="text-yellow-500">✦</span> Owner @ InnoVision Labs</li>
        </ul>
      </div>

      {/* Physical & Hardware */}
      <div class="p-8 bg-zinc-100 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl transition-colors duration-500">
        <h3 class="text-xl font-bold text-zinc-900 dark:text-white mb-4 transition-colors duration-500">Physical Execution</h3>
        <ul class="space-y-3 text-zinc-600 dark:text-zinc-400 transition-colors duration-500">
          <li class="flex items-center gap-2"><span class="text-red-500">✦</span> 1st Dan Black Belt (Shotokan Karate)</li>
          <li class="flex items-center gap-2"><span class="text-red-500">✦</span> Active Dojo Sensei</li>
          <li class="flex items-center gap-2"><span class="text-red-500">✦</span> Hardware Prototyping (VELOX Food Service Robot)</li>
          <li class="flex items-center gap-2"><span class="text-red-500">✦</span> Automotive Enthusiast (W124 E500, WRX STI)</li>
        </ul>
      </div>

    </section>

    {/* Contact / Closing */}
    <section class="border-t border-zinc-200 dark:border-zinc-800 pt-12 transition-colors duration-500">
      <p class="text-zinc-500 font-bold uppercase tracking-widest text-sm mb-6">Status // Available for collaboration</p>
      <a href="mailto:chathurakulathunga.foxc@gmail.com" class="inline-flex items-center px-8 py-4 bg-zinc-900 dark:bg-white text-white dark:text-black font-bold rounded-lg hover:bg-zinc-700 dark:hover:bg-zinc-200 transition-colors duration-500">
        Initiate Contact
      </a>
    </section>

  </div>
</Layout>