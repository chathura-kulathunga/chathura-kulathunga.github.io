---
import { sanityClient } from 'sanity:client';
import imageUrlBuilder from '@sanity/image-url';
import { PortableText } from 'astro-portabletext';
import '../../styles/global.css'; 

// 1. Tell Astro to build a page for every project in Sanity
export async function getStaticPaths() {
  const projects = await sanityClient.fetch(`*[_type == "softwareProject" && defined(slug.current)]`);
  
  return projects.map((project: any) => ({
    params: { slug: project.slug.current },
    props: { project }, // Pass the project data to the page
  }));
}

// 2. Grab the specific project data for the current page
const { project } = Astro.props as any;

// 3. Image setup
const builder = imageUrlBuilder(sanityClient);
function urlFor(source: any) {
  return builder.image(source);
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{project.title} | The Vault</title>
  </head>
  
  <body class="bg-zinc-950 text-zinc-300 font-sans antialiased min-h-screen p-8 md:p-16 max-w-4xl mx-auto">
    
    {/* Navigation Back Button */}
    <a href="/" class="inline-flex items-center text-sm font-bold text-zinc-500 hover:text-white mb-12 transition-colors uppercase tracking-wider">
      ← Back to Vault
    </a>

    {/* Hero Section */}
    <header class="mb-12">
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 tracking-tight">{project.title}</h1>
      
      <div class="flex flex-wrap gap-2 mb-8">
        {project.techStack && project.techStack.map((tech: string) => (
          <span class="bg-zinc-900 border border-zinc-700 px-4 py-1.5 rounded-md text-xs font-bold text-zinc-300 uppercase tracking-wider">
            {tech}
          </span>
        ))}
      </div>
    </header>

    {/* Full Cover Image */}
    {project.mainImage && (
      <div class="w-full mb-16 rounded-xl overflow-hidden border border-zinc-800 shadow-2xl">
        <img 
          src={urlFor(project.mainImage).width(1200).height(600).url()} 
          alt="Project Cover" 
          class="w-full h-auto object-cover"
        />
      </div>
    )}

    {/* The Full Detailed Article */}
    {project.body && (
      <article class="prose prose-invert prose-zinc max-w-none 
                      [&>h1]:text-3xl [&>h1]:font-bold [&>h1]:text-white [&>h1]:mt-12 [&>h1]:mb-6
                      [&>h2]:text-2xl [&>h2]:font-bold [&>h2]:text-zinc-100 [&>h2]:mt-10 [&>h2]:mb-4
                      [&>p]:text-zinc-400 [&>p]:leading-relaxed [&>p]:mb-6
                      [&>ul]:list-disc [&>ul]:pl-6 [&>ul]:mb-6 [&>ul]:text-zinc-400
                      [&>li]:mb-2">
        <PortableText value={project.body} />
      </article>
    )}

    {/* Bottom Actions */}
    {project.githubUrl && (
      <div class="mt-16 pt-8 border-t border-zinc-800">
        <a href={project.githubUrl} target="_blank" class="inline-flex items-center px-6 py-3 bg-white text-black font-bold rounded-lg hover:bg-zinc-200 transition-colors">
          View GitHub Repository
        </a>
      </div>
    )}

  </body>
</html>