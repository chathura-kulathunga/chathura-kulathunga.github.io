---
import { sanityClient } from 'sanity:client';
import imageUrlBuilder from '@sanity/image-url';
import { PortableText } from 'astro-portabletext';
import Layout from '../../layouts/Layout.astro'; 

export async function getStaticPaths() {
  const milestones = await sanityClient.fetch(`*[_type == "dojoMilestone" && defined(slug.current)]`);
  
  return milestones.map((milestone: any) => ({
    params: { slug: milestone.slug.current },
    props: { milestone },
  }));
}

const { milestone } = Astro.props as any;

const builder = imageUrlBuilder(sanityClient);
function urlFor(source: any) {
  return builder.image(source);
}

// Format the date nicely
const formattedDate = milestone.date ? new Date(milestone.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}) : '';
---

<Layout title={`${milestone.title} | The Dojo`}>
  
  <div class="max-w-4xl mx-auto px-8 md:px-16 py-12">
    
    <a href="/" class="inline-flex items-center text-sm font-bold text-zinc-500 hover:text-amber-500 mb-12 transition-colors duration-500 uppercase tracking-wider">
      ← Back to Vault
    </a>

    <header class="mb-12">
      <h1 class="text-4xl md:text-6xl font-bold text-zinc-900 dark:text-white mb-4 tracking-tight transition-colors duration-500">{milestone.title}</h1>
      
      {formattedDate && (
        <div class="text-amber-600 dark:text-amber-500 font-bold tracking-widest uppercase text-sm mb-8">
          Recorded: {formattedDate}
        </div>
      )}
    </header>

    {milestone.coverImage && (
      <div class="w-full mb-16 rounded-xl overflow-hidden border border-zinc-200 dark:border-zinc-800 shadow-2xl transition-colors duration-500">
        <img 
          src={urlFor(milestone.coverImage).width(1200).height(600).url()} 
          alt="Milestone Cover" 
          class="w-full h-auto object-cover"
        />
      </div>
    )}

    {milestone.description && (
      <article class="prose max-w-none transition-colors duration-500
                      [&>h1]:text-3xl [&>h1]:font-bold [&>h1]:text-zinc-900 dark:[&>h1]:text-white [&>h1]:mt-12 [&>h1]:mb-6
                      [&>h2]:text-2xl [&>h2]:font-bold [&>h2]:text-zinc-800 dark:[&>h2]:text-zinc-100 [&>h2]:mt-10 [&>h2]:mb-4
                      [&>p]:text-zinc-600 dark:[&>p]:text-zinc-400 [&>p]:leading-relaxed [&>p]:mb-6
                      [&>ul]:list-disc [&>ul]:pl-6 [&>ul]:mb-6 [&>ul]:text-zinc-600 dark:[&>ul]:text-zinc-400
                      [&>li]:mb-2 [&>strong]:text-zinc-900 dark:[&>strong]:text-white">
        <PortableText value={milestone.description} />
      </article>
    )}

  </div>
  
</Layout>