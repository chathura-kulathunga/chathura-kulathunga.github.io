          <a href="https://linkedin.com/in/chathura-kulathunga-b75817276" target="_blank" class="w-10 h-10 md:w-12 md:h-12 bg-white/90 lg:bg-zinc-200 dark:bg-black/90 lg:dark:bg-zinc-800 backdrop-blur-sm lg:backdrop-blur-none flex items-center justify-center rounded text-zinc-900 dark:text-white hover:bg-zinc-900 hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors shadow-sm lg:shadow-none"><svg class="w-4 h-4 md:w-5 md:h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg></a>
        </div>

        <a href="/vault" class="inline-flex items-center gap-6 group cursor-pointer w-fit lg:drop-shadow-none drop-shadow-md">
          <span class="text-xs font-black tracking-[0.3em] uppercase text-zinc-900 dark:text-white group-hover:opacity-70 transition-opacity">Access The Vault</span>
          <div class="w-12 h-0.5 bg-zinc-900 dark:bg-white group-hover:w-24 transition-all duration-500 ease-out"></div>
        </a>

      </div>
    </div>

    <div class="absolute inset-0 lg:relative lg:inset-auto lg:w-1/2 bg-transparent lg:bg-[#F8F9FA] lg:dark:bg-[#121212] flex items-end justify-center z-10 overflow-hidden pointer-events-none">
      <div class="absolute inset-x-0 top-0 h-[60%] bg-linear-to-b from-[#F8F9FA]/80 to-transparent dark:from-[#121212]/90 dark:to-transparent lg:hidden z-10 pointer-events-none"></div>
      <img 
        src="/Chathura-Kulathunga-2025.jpg" 
        alt="Chathura Kulathunga" 
        class="absolute bottom-0 left-1/2 -translate-x-1/2 h-full w-auto max-w-none object-contain object-bottom drop-shadow-3xl z-0 lg:z-20 pointer-events-none" 
      />
    </div>
  </section>

  {/* ========================================= */}
  {/* VISUAL ARCHIVES GALLERY                   */}
  {/* ========================================= */}
  <section class="relative z-30 w-full px-0 md:px-12 lg:px-24 pb-16 -mt-32 md:-mt-48 lg:mt-16">
    
    {/* UPGRADED: Added scroll-smooth so it glides naturally on release! */}
    <div id="archive-gallery" class="flex overflow-x-auto lg:grid lg:grid-cols-5 gap-4 md:gap-6 px-6 md:px-0 pb-8 snap-x snap-mandatory scroll-smooth hide-scrollbar cursor-grab active:cursor-grabbing select-none">
      
      <div class="relative min-w-[65vw] sm:min-w-[45vw] lg:min-w-0 aspect-4/5 snap-center overflow-hidden border-2 border-zinc-200 dark:border-zinc-800 bg-zinc-100 dark:bg-zinc-900 group shadow-2xl lg:shadow-none">
        <img src="/a.jpg" alt="Archive A" class="gallery-img w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105 cursor-pointer" draggable="false" />
      </div>

      <div class="relative min-w-[65vw] sm:min-w-[45vw] lg:min-w-0 aspect-4/5 snap-center overflow-hidden border-2 border-zinc-200 dark:border-zinc-800 bg-zinc-100 dark:bg-zinc-900 group shadow-2xl lg:shadow-none">
        <img src="/b.jpg" alt="Archive B" class="gallery-img w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105 cursor-pointer" draggable="false" />
      </div>

      <div class="relative min-w-[65vw] sm:min-w-[45vw] lg:min-w-0 aspect-4/5 snap-center overflow-hidden border-2 border-zinc-200 dark:border-zinc-800 bg-zinc-100 dark:bg-zinc-900 group shadow-2xl lg:shadow-none">
        <img src="/c.jpg" alt="Archive C" class="gallery-img w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105 cursor-pointer" draggable="false" />
      </div>

      <div class="relative min-w-[65vw] sm:min-w-[45vw] lg:min-w-0 aspect-4/5 snap-center overflow-hidden border-2 border-zinc-200 dark:border-zinc-800 bg-zinc-100 dark:bg-zinc-900 group shadow-2xl lg:shadow-none">
        <img src="/d.jpg" alt="Archive D" class="gallery-img w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105 cursor-pointer" draggable="false" />
      </div>

      <div class="relative min-w-[65vw] sm:min-w-[45vw] lg:min-w-0 aspect-4/5 snap-center overflow-hidden border-2 border-zinc-200 dark:border-zinc-800 bg-zinc-100 dark:bg-zinc-900 group shadow-2xl lg:shadow-none">
        <img src="/e.jpg" alt="Archive E" class="gallery-img w-full h-full object-cover filter grayscale group-hover:grayscale-0 transition-all duration-700 group-hover:scale-105 cursor-pointer" draggable="false" />
      </div>

    </div>
  </section>

  {/* ========================================= */}
  {/* DISCIPLINE NAVIGATION PROMPT              */}
  {/* ========================================= */}
  <div class="w-full flex justify-center pb-24 relative z-20">
    <div class="flex flex-col items-center gap-6 opacity-60 hover:opacity-100 transition-opacity duration-300">
      <p class="text-[10px] md:text-xs font-black tracking-[0.3em] uppercase text-zinc-900 dark:text-white text-center">
        <span class="block lg:hidden">Access Disciplines Via Menu</span>
        <span class="hidden lg:block">Explore Skill Sectors Above</span>
      </p>
      <div class="w-px h-16 bg-zinc-900 dark:bg-white animate-pulse"></div>
    </div>
  </div>

  {/* ========================================= */}
  {/* FRAMED LIGHTBOX SYSTEM                    */}
  {/* ========================================= */}
  <div id="gallery-lightbox" class="fixed inset-0 z-100 bg-zinc-900/95 dark:bg-black/95 backdrop-blur-md flex items-center justify-center p-4 opacity-0 transition-opacity duration-300">
    
    <div class="relative flex flex-col items-end">
      <button id="close-lightbox" class="mb-3 text-white/50 hover:text-white transition-all duration-300 cursor-pointer p-2 z-50 bg-white/10 hover:bg-white/20 rounded-full backdrop-blur-sm shadow-xl">
        <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
      
      <img id="lightbox-image" src="" class="max-w-[85vw] md:max-w-2xl max-h-[75vh] object-contain drop-shadow-2xl scale-95 transition-transform duration-500 ease-out pointer-events-none rounded-sm border border-zinc-800" />
    </div>

  </div>

</Layout>

<script>
  const setupGalleryEngine = () => {
    // 1. LIGHTBOX LOGIC
    const lightbox = document.getElementById('gallery-lightbox');
    const lightboxImg = document.getElementById('lightbox-image') as HTMLImageElement;
    const closeBtn = document.getElementById('close-lightbox');
    const galleryTriggers = document.querySelectorAll('.gallery-img');

    const openModal = (src: string) => {
      if (!lightbox || !lightboxImg) return;
      lightboxImg.src = src;
      lightbox.classList.remove('hidden');
      void lightbox.offsetWidth; // Force reflow
      lightbox.classList.remove('opacity-0');
      lightboxImg.classList.remove('scale-95');
      lightboxImg.classList.add('scale-100');
      document.body.style.overflow = 'hidden';
    };

    const closeModal = () => {
      if (!lightbox || !lightboxImg) return;
      lightbox.classList.add('opacity-0');
      lightboxImg.classList.remove('scale-100');
      lightboxImg.classList.add('scale-95');
      setTimeout(() => {
        lightbox.classList.add('hidden');
        document.body.style.overflow = '';
      }, 300); 
    };

    if (closeBtn && lightbox) {
      closeBtn.addEventListener('click', closeModal);
      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) closeModal(); 
      });
    }

    // 2. ULTRA-SMOOTH KINETIC DRAG LOGIC
    const gallery = document.getElementById('archive-gallery');
    let isDown = false;
    let isDragging = false;
    let startX: number;
    let scrollLeft: number;

    if (gallery) {
      gallery.addEventListener('mousedown', (e) => {
        isDown = true;
        isDragging = false;
        
        // UPGRADED: Instantly remove smooth scrolling while the mouse is down so it perfectly follows your hand!
        gallery.classList.remove('snap-mandatory', 'scroll-smooth'); 
        
        startX = e.pageX - gallery.offsetLeft;
        scrollLeft = gallery.scrollLeft;
      });

      gallery.addEventListener('mouseleave', () => {
        isDown = false;
        // Turn the glide back on
        gallery.classList.add('snap-mandatory', 'scroll-smooth');
      });

      gallery.addEventListener('mouseup', () => {
        isDown = false;
        // Turn the glide back on when releasing the mouse
        gallery.classList.add('snap-mandatory', 'scroll-smooth');
      });

      gallery.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        isDragging = true; 
        const x = e.pageX - gallery.offsetLeft;
        
        // UPGRADED: Changed multiplier from 2 to 1.5 for a softer, more premium pull
        const walk = (x - startX) * 1.5; 
        gallery.scrollLeft = scrollLeft - walk;
      });

      // 3. SMART CLICK HANDLER
      galleryTriggers.forEach(img => {
        img.addEventListener('click', (e) => {
          if (isDragging) {
            e.preventDefault();
            e.stopPropagation();
            return;
          }
          const target = e.target as HTMLImageElement;
          openModal(target.src);
        });
      });
    }
  };

  document.addEventListener('astro:page-load', setupGalleryEngine);
</script>

<style>
  .drop-shadow-3xl {
    filter: drop-shadow(0 25px 35px rgba(0, 0, 0, 0.4));
  }
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .hide-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>