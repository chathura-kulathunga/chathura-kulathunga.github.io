---
import { sanityClient } from 'sanity:client';
import imageUrlBuilder from '@sanity/image-url';
import Layout from '../layouts/Layout.astro'; 

const builder = imageUrlBuilder(sanityClient);
function urlFor(source: any) {
  return builder.image(source);
}

// Fetch ALL databases!
const projects = await sanityClient.fetch(`*[_type == "softwareProject"]`);
const labs = await sanityClient.fetch(`*[_type == "cyberLab"]`);
// Order the Dojo events by date descending (newest first)
const milestones = await sanityClient.fetch(`*[_type == "dojoMilestone"] | order(date desc)`);
---

<Layout title="The Vault | Chathura Kulathunga">
  
  <div class="max-w-7xl mx-auto px-8 md:px-16 py-12">
    
    {/* ========================================= */}
    {/* SECTION 1: SOFTWARE ENGINEERING           */}
    {/* ========================================= */}
    <header class="mb-12 border-b border-zinc-200 dark:border-zinc-800 pb-8 transition-colors duration-500">
      <h1 class="text-4xl md:text-5xl font-bold text-zinc-900 dark:text-white tracking-tight transition-colors duration-500">Software Vault.</h1>
      <p class="text-zinc-500 dark:text-zinc-500 mt-2 text-lg transition-colors duration-500">Engineering & Development Architecture</p>
    </header>
    
    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-24">
      {projects.map((project: any) => (
        <li class="group bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl overflow-hidden hover:border-zinc-400 dark:hover:border-zinc-500 transition-all duration-500 shadow-xl flex flex-col relative">
          
          {project.mainImage && (
            <a href={`/project/${project.slug?.current}`} class="w-full h-56 overflow-hidden bg-zinc-100 dark:bg-zinc-800 shrink-0 block">
              <img 
                src={urlFor(project.mainImage).width(800).height(500).url()} 
                alt="Project Cover" 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            </a>
          )}
          
          <div class="p-6 flex flex-col grow">
            <a href={`/project/${project.slug?.current}`}>
              <h2 class="text-2xl font-bold text-zinc-900 dark:text-white mb-4 hover:text-zinc-600 dark:hover:text-zinc-300 transition-colors duration-500">{project.title}</h2>
            </a>
            
            <div class="flex flex-wrap gap-2 mb-4 shrink-0">
              {project.techStack && project.techStack.map((tech: string) => (
                <span class="bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-700 px-3 py-1 rounded-md text-xs font-semibold text-zinc-600 dark:text-zinc-400 uppercase tracking-wider transition-colors duration-500">
                  {tech}
                </span>
              ))}
            </div>

            <p class="text-zinc-600 dark:text-zinc-400 mb-6 leading-relaxed shrink-0 transition-colors duration-500">
              {project.description}
            </p>
            
            <div class="mt-auto pt-6 border-t border-zinc-200 dark:border-zinc-800 flex justify-between items-center transition-colors duration-500">
              <a href={`/project/${project.slug?.current}`} class="inline-flex items-center text-sm font-bold text-zinc-900 dark:text-white hover:text-zinc-600 dark:hover:text-zinc-400 transition-colors duration-500">
                Read Case Study →
              </a>
              {project.githubUrl && (
                <a href={project.githubUrl} target="_blank" class="inline-flex items-center text-sm font-semibold text-zinc-400 dark:text-zinc-500 hover:text-zinc-900 dark:hover:text-white transition-colors duration-500">
                  GitHub ↗
                </a>
              )}
            </div>
          </div>
        </li>
      ))}
    </ul>

    {/* ========================================= */}
    {/* SECTION 2: CYBERSECURITY LABS             */}
    {/* ========================================= */}
    <header class="mb-12 border-b border-zinc-200 dark:border-zinc-800 pb-8 transition-colors duration-500">
      <h2 class="text-3xl md:text-4xl font-bold text-zinc-900 dark:text-white tracking-tight transition-colors duration-500">Cybersecurity Labs.</h2>
      <p class="text-zinc-500 dark:text-zinc-500 mt-2 text-lg transition-colors duration-500">Vulnerability Research & Network Analysis</p>
    </header>

    <ul class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-24">
      {labs.map((lab: any) => (
        <li class="group bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl overflow-hidden hover:border-red-400 dark:hover:border-red-500 transition-all duration-500 shadow-xl flex flex-col relative">
          
          <div class="p-6 flex flex-col grow">
            <a href={`/labs/${lab.slug?.current}`}>
              <h3 class="text-2xl font-bold text-zinc-900 dark:text-white mb-4 hover:text-red-600 dark:hover:text-red-400 transition-colors duration-500">{lab.title}</h3>
            </a>
            
            <div class="flex flex-wrap gap-2 mb-4 shrink-0">
              {lab.toolsUsed && lab.toolsUsed.map((tool: string) => (
                <span class="bg-red-50 dark:bg-red-950/30 border border-red-200 dark:border-red-900 px-3 py-1 rounded-md text-xs font-bold text-red-700 dark:text-red-400 uppercase tracking-wider transition-colors duration-500">
                  {tool}
                </span>
              ))}
            </div>

            <p class="text-zinc-600 dark:text-zinc-400 mb-6 leading-relaxed shrink-0 transition-colors duration-500">
              {lab.executiveSummary}
            </p>
            
            <div class="mt-auto pt-6 border-t border-zinc-200 dark:border-zinc-800 transition-colors duration-500">
              <a href={`/labs/${lab.slug?.current}`} class="inline-flex items-center text-sm font-bold text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 transition-colors duration-500">
                View Lab Report →
              </a>
            </div>
          </div>
        </li>
      ))}
    </ul>

    {/* ========================================= */}
    {/* SECTION 3: THE DOJO                       */}
    {/* ========================================= */}
    <header class="mb-12 border-b border-zinc-200 dark:border-zinc-800 pb-8 transition-colors duration-500">
      <h2 class="text-3xl md:text-4xl font-bold text-zinc-900 dark:text-white tracking-tight transition-colors duration-500">The Dojo.</h2>
      <p class="text-zinc-500 dark:text-zinc-500 mt-2 text-lg transition-colors duration-500">Shotokan Karate // 1st Dan Records</p>
    </header>

    <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {milestones.map((milestone: any) => (
        <li class="group bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl overflow-hidden hover:border-amber-400 dark:hover:border-amber-500 transition-all duration-500 shadow-xl flex flex-col relative">
          
          {milestone.coverImage && (
            <a href={`/dojo/${milestone.slug?.current}`} class="w-full h-48 overflow-hidden bg-zinc-100 dark:bg-zinc-800 shrink-0 block">
              <img 
                src={urlFor(milestone.coverImage).width(600).height(400).url()} 
                alt="Milestone Cover" 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 grayscale group-hover:grayscale-0"
              />
            </a>
          )}
          
          <div class="p-6 flex flex-col grow">
            
            {milestone.date && (
              <span class="text-amber-600 dark:text-amber-500 font-bold uppercase tracking-widest text-xs mb-3">
                {new Date(milestone.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
            )}
            
            <a href={`/dojo/${milestone.slug?.current}`}>
              <h3 class="text-xl font-bold text-zinc-900 dark:text-white mb-4 hover:text-amber-600 dark:hover:text-amber-400 transition-colors duration-500">{milestone.title}</h3>
            </a>
            
            <div class="mt-auto pt-6 border-t border-zinc-200 dark:border-zinc-800 transition-colors duration-500">
              <a href={`/dojo/${milestone.slug?.current}`} class="inline-flex items-center text-sm font-bold text-amber-600 dark:text-amber-500 hover:text-amber-800 dark:hover:text-amber-300 transition-colors duration-500">
                View Milestone →
              </a>
            </div>
          </div>
        </li>
      ))}
    </ul>

  </div>

</Layout>