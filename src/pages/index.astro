---
import { sanityClient } from 'sanity:client';
import imageUrlBuilder from '@sanity/image-url';
import '../styles/global.css';

const builder = imageUrlBuilder(sanityClient);
function urlFor(source: any) {
  return builder.image(source);
}

// Fetch all projects
const projects = await sanityClient.fetch(`*[_type == "softwareProject"]`);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>The Vault | Chathura Kulathunga</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  
  <body class="bg-zinc-950 text-zinc-300 font-sans antialiased min-h-screen p-8 md:p-16">
    <div class="max-w-7xl mx-auto">
      
      <header class="mb-16 border-b border-zinc-800 pb-8">
        <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tight">Software Vault.</h1>
        <p class="text-zinc-500 mt-2 text-lg">Engineering & Development Architecture</p>
      </header>
      
      <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project: any) => (
          
          <li class="group bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden hover:border-zinc-500 transition-all duration-300 shadow-lg flex flex-col relative">
            
            {/* Clickable Cover Image */}
            {project.mainImage && (
              <a href={`/project/${project.slug?.current}`} class="w-full h-56 overflow-hidden bg-zinc-800 shrink-0 block">
                <img 
                  src={urlFor(project.mainImage).width(800).height(500).url()} 
                  alt="Project Cover" 
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </a>
            )}
            
            <div class="p-6 flex flex-col grow">
              
              {/* Clickable Title */}
              <a href={`/project/${project.slug?.current}`}>
                <h2 class="text-2xl font-bold text-white mb-4 hover:text-zinc-300 transition-colors">{project.title}</h2>
              </a>
              
              <div class="flex flex-wrap gap-2 mb-4 shrink-0">
                {project.techStack && project.techStack.map((tech: string) => (
                  <span class="bg-zinc-950 border border-zinc-700 px-3 py-1 rounded-md text-xs font-semibold text-zinc-400 uppercase tracking-wider">
                    {tech}
                  </span>
                ))}
              </div>

              <p class="text-zinc-400 mb-6 leading-relaxed shrink-0">
                {project.description}
              </p>
              
              {/* Card Footer with Links */}
              <div class="mt-auto pt-6 border-t border-zinc-800 flex justify-between items-center">
                <a href={`/project/${project.slug?.current}`} class="inline-flex items-center text-sm font-bold text-white hover:text-zinc-400 transition-colors">
                  Read Case Study →
                </a>

                {project.githubUrl && (
                  <a href={project.githubUrl} target="_blank" class="inline-flex items-center text-sm font-semibold text-zinc-500 hover:text-white transition-colors">
                    GitHub ↗
                  </a>
                )}
              </div>

            </div>
            
          </li>
        ))}
      </ul>
      
    </div>
  </body>
</html>