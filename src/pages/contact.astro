---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | CK Vault">
  
  <div class="max-w-4xl mx-auto px-6 md:px-12 py-16 md:py-24">
    
    <div class="flex flex-col items-center animate-fade-in pb-12">
      
      {/* Boxed Header */}
      <div class="border-4 border-zinc-900 dark:border-white px-8 py-4 mb-8 inline-block">
        <h1 class="text-xl md:text-2xl font-black text-zinc-900 dark:text-white tracking-[0.3em] uppercase">
          Contact
        </h1>
      </div>

      <p class="text-zinc-500 dark:text-zinc-400 font-medium mb-16 text-center max-w-lg">
        Currently open for software engineering roles, security audits, and architectural consultations. Initiate a connection below.
      </p>

      {/* Figma-Style Form */}
      <form class="w-full max-w-lg flex flex-col gap-12 pb-8">
        
        {/* Name */}
        <div class="relative group mt-2">
          <input type="text" id="name" required class="w-full bg-transparent border-b-2 border-zinc-900 dark:border-zinc-700 focus:border-zinc-500 dark:focus:border-white text-zinc-900 dark:text-white font-bold text-sm tracking-widest uppercase py-3 outline-none transition-colors peer" placeholder=" " />
          <label for="name" class="absolute left-0 -top-4 text-[10px] text-zinc-500 dark:text-zinc-300 font-bold tracking-widest uppercase transition-all duration-300 peer-placeholder-shown:top-3 peer-placeholder-shown:text-xs peer-focus:-top-4 peer-focus:text-[10px] pointer-events-none">
            Enter Your Name *
          </label>
        </div>

        {/* Email */}
        <div class="relative group">
          <input type="email" id="email" required class="w-full bg-transparent border-b-2 border-zinc-900 dark:border-zinc-700 focus:border-zinc-500 dark:focus:border-white text-zinc-900 dark:text-white font-bold text-sm tracking-widest uppercase py-3 outline-none transition-colors peer" placeholder=" " />
          <label for="email" class="absolute left-0 -top-4 text-[10px] text-zinc-500 dark:text-zinc-300 font-bold tracking-widest uppercase transition-all duration-300 peer-placeholder-shown:top-3 peer-placeholder-shown:text-xs peer-focus:-top-4 peer-focus:text-[10px] pointer-events-none">
            Enter Your Email *
          </label>
        </div>

        {/* Phone */}
        <div class="relative group">
          <input type="tel" id="phone" class="w-full bg-transparent border-b-2 border-zinc-900 dark:border-zinc-700 focus:border-zinc-500 dark:focus:border-white text-zinc-900 dark:text-white font-bold text-sm tracking-widest uppercase py-3 outline-none transition-colors peer" placeholder=" " />
          <label for="phone" class="absolute left-0 -top-4 text-[10px] text-zinc-500 dark:text-zinc-300 font-bold tracking-widest uppercase transition-all duration-300 peer-placeholder-shown:top-3 peer-placeholder-shown:text-xs peer-focus:-top-4 peer-focus:text-[10px] pointer-events-none">
            Phone Number
          </label>
        </div>

        {/* Message */}
        <div class="relative group">
          <textarea id="message" rows="1" required class="w-full bg-transparent border-b-2 border-zinc-900 dark:border-zinc-700 focus:border-zinc-500 dark:focus:border-white text-zinc-900 dark:text-white font-bold text-sm tracking-widest uppercase py-3 outline-none transition-colors peer resize-none" placeholder=" "></textarea>
          <label for="message" class="absolute left-0 -top-4 text-[10px] text-zinc-500 dark:text-zinc-300 font-bold tracking-widest uppercase transition-all duration-300 peer-placeholder-shown:top-3 peer-placeholder-shown:text-xs peer-focus:-top-4 peer-focus:text-[10px] pointer-events-none">
            Your Message *
          </label>
        </div>

        {/* Submit Button */}
        <div class="pt-6 flex justify-center">
          <button type="submit" class="flex items-center gap-6 group cursor-pointer">
            <div class="h-6 w-0.5 bg-zinc-900 dark:bg-white group-hover:scale-y-150 transition-transform duration-300"></div>
            <span class="text-xs font-black text-zinc-900 dark:text-white tracking-[0.2em] uppercase group-hover:opacity-70 transition-opacity">
              Submit
            </span>
            <div class="h-6 w-0.5 bg-zinc-900 dark:bg-white group-hover:scale-y-150 transition-transform duration-300"></div>
          </button>
        </div>

      </form>

      {/* ========================================= */}
      {/* DIRECT CONNECTION (SOCIALS)               */}
      {/* ========================================= */}
      <div class="w-full max-w-lg border-t border-zinc-200/50 dark:border-zinc-800/50 pt-12 mt-8 flex flex-col items-center">
        <h3 class="text-[10px] font-black tracking-[0.3em] uppercase text-zinc-400 dark:text-zinc-500 mb-8">
          Direct Channels
        </h3>
        
        <div class="flex items-center justify-center gap-6 md:gap-10">
          
          <a href="https://linkedin.com/" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-[#0A66C2] transition-all duration-300 hover:scale-110">
            <svg class="w-8 h-8 md:w-10 md:h-10 lg:w-12 lg:h-12" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>

          <a href="https://github.com/chathura-kulathunga" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-all duration-300 hover:scale-110">
            <svg class="w-8 h-8 md:w-10 md:h-10 lg:w-12 lg:h-12" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>

          <a href="https://instagram.com/" target="_blank" rel="noopener noreferrer" class="text-zinc-400 hover:text-[#E1306C] transition-all duration-300 hover:scale-110">
            <svg class="w-8 h-8 md:w-10 md:h-10 lg:w-12 lg:h-12" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>

          <a href="mailto:your-email@example.com" class="text-zinc-400 hover:text-[#EA4335] transition-all duration-300 hover:scale-110">
            <svg class="w-8 h-8 md:w-10 md:h-10 lg:w-12 lg:h-12" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12.713l11.985-8.713h-23.97l11.985 8.713zm0 2.574l-12-8.723v13.436h24v-13.436l-12 8.723z"/></svg>
          </a>

        </div>
      </div>

    </div>

  </div>

</Layout>

<style>
  .animate-fade-in { animation: fadeIn 1s ease-out forwards; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

  /* Mobile autofill text color override */
  input:-webkit-autofill,
  textarea:-webkit-autofill {
    -webkit-background-clip: text;
    transition: background-color 5000s ease-in-out 0s;
  }
</style>